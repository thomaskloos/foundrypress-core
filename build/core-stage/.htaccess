RewriteEngine On

# Preserve existing files and directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Backward compatibility for old hub config links
RewriteRule ^hub/config\.php$ /hub/license.php [R=301,L]
RewriteRule ^hub/config/?$ /hub/license.php [R=301,L]

# Hub routes
RewriteRule ^hub/?$ /hub/index.php [L,QSA]
RewriteRule ^hub/login/?$ /hub/login.php [L,QSA]
RewriteRule ^hub/logout/?$ /hub/logout.php [L,QSA]
RewriteRule ^hub/license/?$ /hub/license.php [L,QSA]
RewriteRule ^hub/setup-password/?$ /hub/setup-password.php [L,QSA]

# Article routes
RewriteRule ^articles/([^/]+)/?$ /articles/index.php?brand=$1 [L,QSA]
RewriteRule ^articles/([^/]+)/([^/]+)/?$ /articles/read.php?brand=$1&slug=$2 [L,QSA]

# Fallback to main index
RewriteRule ^$ /index.php [L]